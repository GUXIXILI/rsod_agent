# ── 环境变量（敏感信息）──────────────────────────────
.env
.env.local
.env.*.local

# ── Python 虚拟环境 ──────────────────────────────────
.venv/
venv/
ENV/
env/

# ── Python 缓存与构建产物 ────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ── 前端依赖与构建产物 ───────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── 日志文件 ─────────────────────────────────────────
*.log
logs/

# ── IDE 与编辑器配置 ─────────────────────────────────
