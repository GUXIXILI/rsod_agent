# ═══════════════════════════════════════════════════════
# 基于 YOLOv11 的目标检测智能体平台 — 环境变量配置
# ═══════════════════════════════════════════════════════

# ── OpenAI API 配置（根据项目需求进行修改使用） ─────────────────────────
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Qwen API 配置 ───────────────────────────────────
QWEN_API_KEY=sk-your-qwen-api-key
QWEN_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
# Qwen 兼容模式 API（用于 LangChain OpenAI 客户端）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── 数据库配置 ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=rsod_agent
DB_USER=rsod_admin
DB_PASSWORD=rsod_admin

# 开发环境：本地 Docker
DATABASE_URL=postgresql://rsod_admin:rsod_admin@localhost:5433/rsod_agent
# 生产环境：取消下一行的注释并注释掉上面的行
# DATABASE_URL=postgresql://your-database-username:your-secure-password@your-host:5432/your-database-name

# ── Redis 配置 ───────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# 开发环境：本地 Docker
REDIS_URL=redis://localhost:6379/0
# 生产环境：取消下一行的注释并注释掉上面的行
# REDIS_URL=redis://:your-redis-password@your-redis-host:6379/0

# ── 本地 LLM 配置（可选）────────────────────
USE_LOCAL_LLM=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── MinIO 对象存储配置 ───────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rsod-agent-images
MINIO_SECURE=false

# ── JWT 认证配置 ─────────────────────────────────────
# 重要：JWT_SECRET_KEY 必须设置为长度 ≥ 32 位的强随机字符串。
# 留空或长度不足时，系统启动会发出安全警告，生产环境请务必修改。
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── 应用配置 ─────────────────────────────────────────
APP_NAME=GLW RSOD Agent Platform
APP_VERSION=0.1.0
# 生产环境请保持 false，避免泄露 SQL 等调试信息
DEBUG=false
LOG_LEVEL=INFO

# ── 火灾烟雾检测配置 ─────────────────────────────────
FIRE_SMOKE_MODEL_PATH=runs/fire_smoke/yolo11n_e50_b16_s42/weights/best.pt
# CUDA 显卡使用 0；无 CUDA 环境可改为 cpu
FIRE_SMOKE_DEVICE=0
# 单图平衡模式阈值
FIRE_SMOKE_IMAGE_FIRE_THRESHOLD=0.25
FIRE_SMOKE_IMAGE_SMOKE_THRESHOLD=0.20
# 视频高召回模式阈值，必须结合连续帧确认
FIRE_SMOKE_VIDEO_FIRE_THRESHOLD=0.20
FIRE_SMOKE_VIDEO_SMOKE_THRESHOLD=0.20
FIRE_SMOKE_FIRE_CONFIRM_FRAMES=3
FIRE_SMOKE_SMOKE_CONFIRM_FRAMES=3

# ── CORS 配置 ────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# ── 天气数据配置 ─────────────────────────────────────
# 天气 API Key（可选，留空则使用模拟数据）
WEATHER_API_KEY=
# 天气 API 提供商：openweathermap/pyowm
WEATHER_API_PROVIDER=pyowm

# ── 交通数据配置 ─────────────────────────────────────
# 交通 API Key（可选）
TRAFFIC_API_KEY=

# ── 危险路况预测调度配置 ────────────────────────────────
# 是否启用定时任务拉取天气数据
SCHEDULER_ENABLED=true
